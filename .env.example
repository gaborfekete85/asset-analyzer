# --- Required ---
TAVILY_API_KEY=tvly-...                  # https://tavily.com (free 1k/mo)

# --- Pick ONE provider ---
# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (uncomment if using OpenAI models)
# OPENAI_API_KEY=sk-...

# --- Model selection (optional) ---
# Use the LangChain `provider:model` convention. Defaults below.

# Single override for all roles:
# ANALYZER_MODEL=openai:gpt-4o-mini

# Per-role overrides take precedence over ANALYZER_MODEL:
# ANALYZER_DISCOVERY_MODEL=anthropic:claude-sonnet-4-6
# ANALYZER_SUBAGENT_MODEL=anthropic:claude-sonnet-4-6
# ANALYZER_SYNTHESIS_MODEL=anthropic:claude-opus-4-7

# --- Cheap OpenAI preset (good for testing) ---
# ANALYZER_DISCOVERY_MODEL=openai:gpt-4o-mini
# ANALYZER_SUBAGENT_MODEL=openai:gpt-4o-mini
# ANALYZER_SYNTHESIS_MODEL=openai:gpt-4o

# --- Output dir ---
# ANALYZER_REPORTS_DIR=reports
